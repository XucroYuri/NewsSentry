# Preserve directory structure
!italy/**/.gitkeep

# Config secrets (env-var placeholders are fine, actual secrets are not)
config/provider/prompts/*.actual.yaml

# Package manager lock files
uv.lock

# OMC plugin state (session-local, not project code)
.omc/

