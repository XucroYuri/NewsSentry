# =============================================================================
# News Sentry v2 — 环境变量模板
# =============================================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# .env 已被 .gitignore 忽略，不会提交到仓库。
# =============================================================================

# ── 必填 ─────────────────────────────────────────────────────────────────────

# 部署 profile: cloud-vps (生产) | local-workstation (开发/测试)
NEWSSENTRY_PROFILE=local-workstation

# 数据输出根目录（相对于项目根），默认: ./data
# NEWSSENTRY_DATA_DIR=./data

# ── AI Provider (至少配置一个) ──────────────────────────────────────────────

# Gemini API (推荐首选)
# 1. 在 https://aistudio.google.com/apikey 创建 key
# 2. 取消注释并填入 key
# GEMINI_API_KEY=xxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-2.0-flash

# DeepSeek API (备选)
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# Groq API (备选，高并发)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
# GROQ_MODEL=llama-3.3-70b-versatile

# Cloudflare Workers AI (额外兜底，需 CF Account ID + API Token)
# CLOUDFLARE_ACCOUNT_ID=xxxxxxxx
# CLOUDFLARE_API_TOKEN=xxxxxxxx

# LibreTranslate (翻译兜底)
# LIBRETRANSLATE_BASE_URL=http://127.0.0.1:5000
# LIBRETRANSLATE_API_KEY=xxxxxxxx

# MyMemory (翻译兜底，无需 key)
# MYMEMORY_EMAIL=your@email.com

# ── 推送通知 (可选) ─────────────────────────────────────────────────────────

# 飞书 Webhook
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# Telegram Bot
# TELEGRAM_BOT_TOKEN=xxxxxxxx
# TELEGRAM_CHAT_ID=xxxxxxxx

# SMTP 邮件
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=xxxxxxxx

# ── Admin / Auth ─────────────────────────────────────────────────────────────

# Admin 面板登录凭据
# NEWSSENTRY_ADMIN_USER=admin
# NEWSSENTRY_ADMIN_PASSWORD=xxxxxxxx

# API Key（逗号分隔多个 key）
# NEWSSENTRY_API_KEY=xxxxxxxx

# ── 代理 (中国大陆环境必需) ──────────────────────────────────────────────────

# 全协议 SOCKS5 代理
# all_proxy=socks5://127.0.0.1:1080

# HTTP/HTTPS 代理
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890

# ── 自动采集与 AI 富化 ──────────────────────────────────────────────────────

# 自动采集开关 (1=启用, 0=禁用)
# NEWSSENTRY_AUTO_COLLECT=1
# NEWSSENTRY_COLLECT_INTERVAL=15
# NEWSSENTRY_TARGET_ID=italy

# AI 富化开关
# NEWSSENTRY_AI_ENRICHMENT=1
# NEWSSENTRY_AI_ENRICH_INTERVAL=60
# NEWSSENTRY_AI_ENRICH_DAILY_LIMIT=45
# NEWSSENTRY_AI_BUDGET_USD=1.0

# ── 公开站点 ─────────────────────────────────────────────────────────────────

# 公开站翻译与发布
# NEWSSENTRY_PUBLIC_TRANSLATION=1
# NEWSSENTRY_PUBLIC_TRANSLATION_INTERVAL=5
# NEWSSENTRY_PUBLIC_SITE_BASE_URL=https://news-sentry.com

# ── CORS ─────────────────────────────────────────────────────────────────────

# 允许的跨源请求来源 (逗号分隔)
# CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ── 部署模式 ─────────────────────────────────────────────────────────────────
# ENABLE_CLOUDFLARE=true 启用 Cloudflare Workers + Pages（需先配好 frontend/cloudflare/）
# 默认 false（FastAPI 全栈）。示例值保留注释态，显式设为 true 才会激活 Cloudflare。
# ENABLE_CLOUDFLARE=true

# 前端构建产物子目录（覆盖 vite outDir，用于 Cloudflare 部署）
# 默认: ../../src/news_sentry/static/{admin,public_app}
# FRONTEND_OUTPUT_SUBDIR=dist/cloudflare

# ── 高级选项 ─────────────────────────────────────────────────────────────────

# 日志级别: DEBUG | INFO | WARNING (默认 WARNING)
# NEWSSENTRY_LOG_LEVEL=INFO

# 部署环境标识
# NEWSSENTRY_DEPLOYMENT_ENV=local-workstation

# 允许输出到项目外目录（安全开关）
# NEWSSENTRY_ALLOW_EXTERNAL_DATA_DIR=0
