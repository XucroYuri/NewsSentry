# =============================================================================
# News Sentry — 环境变量模板
# =============================================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# .env 已被 .gitignore 忽略，不会提交到仓库。
# =============================================================================

# ── 必填 ─────────────────────────────────────────────────────────────────────

# 部署 profile: cloud-vps (生产) | local-workstation (开发/测试)
NEWSSENTRY_PROFILE=local-workstation

# 数据输出根目录（相对于项目根）
# 默认: ./data
# NEWSSENTRY_DATA_DIR=./data

# ── AI Provider (Phase 5 需要; Phase 3 规则引擎不需要) ─────────────────────

# DeepSeek API (当前测试用)
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# OpenAI API (备用)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Anthropic API (备用)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── 推送通知 (可选，走 Hermes Agent 配置) ─────────────────────────────────

# Hermes Agent 信息通道配置（统一通知入口）
# 注意：News Sentry 不硬编码任何具体通知平台，所有告警/通知走 Hermes Agent 配置的信息通道
# 以下为示例 — 实际配置应通过 Hermes Agent 管理界面完成
# HERMES_NOTIFICATION_CHANNEL=feishu_webhook
# HERMES_NOTIFICATION_CHANNEL=telegram_bot
# HERMES_NOTIFICATION_CHANNEL=email_smtp

# ── 浏览器与社媒采集 (Phase 12 需要) ──────────────────────────────────────

# Chromium 可执行文件路径（默认自动检测）
# CHROME_BIN=/usr/bin/chromium

# ChromeDriver 可执行文件路径
# CHROMEDRIVER_BIN=/usr/bin/chromedriver

# Xvfb 虚拟显示器编号（默认 :99）
# DISPLAY=:99

# OpenCLI Bridge — Chrome Native Messaging Host 清单路径
# OPENCLI_NMH_MANIFEST=/etc/opt/chrome/native-messaging-hosts/com.opencli.bridge.json

# Playwright 浏览器下载跳过（Docker 构建时使用）
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=1

# 社媒 Session Profile 目录（含登录态，gitignored）
# NEWSSENTRY_SESSION_PROFILES_DIR=./session-profiles

# Chrome 用户数据目录（OpenCLI Bridge 使用）
# NEWSSENTRY_CHROME_DATA_DIR=./chrome-data

# Computer Use 兜底限制（Phase 12 Layer 3）
# NEWSSENTRY_CU_MAX_USES_PER_SOURCE_PER_DAY=3
# NEWSSENTRY_CU_MAX_COST_PER_RUN=5.0

# ── 代理 (中国大陆环境必需) ──────────────────────────────────────────────────

# 全协议 SOCKS5 代理
# all_proxy=socks5://127.0.0.1:1080

# HTTP/HTTPS 代理
# http_proxy=http://127.0.0.1:7890
# https_proxy=http://127.0.0.1:7890

# ── Cloud VPS 部署 (Phase 15) ────────────────────────────────────────────────

# AI 调用预算上限 USD (默认 1.0)
# NEWSSENTRY_AI_BUDGET_USD=1.0

# 运行目标 (默认 italy)
# TARGET_ID=italy

# 运行阶段 (默认 all)
# RUN_STAGE=all

# ── CORS (Web UI 跨源访问) ──────────────────────────────────────────────────

# 允许的跨源请求来源 (逗号分隔)
# 默认: http://localhost:8000,http://localhost:3000
# Cloudflare Pages 部署时建议添加: https://news-sentry.pages.dev
# CORS_ALLOWED_ORIGINS=http://localhost:8000,https://news-sentry.pages.dev

# ── 高级选项 ─────────────────────────────────────────────────────────────────

# 项目根目录覆盖（通常不需要设置）
# NEWSSENTRY_PROJECT_ROOT=/path/to/NewsSentry

# 允许输出到项目外目录（安全开关，默认关闭）
# NEWSSENTRY_ALLOW_EXTERNAL_OUTPUT=0

# 日志级别: DEBUG | INFO | WARNING (默认 WARNING)
# NEWSSENTRY_LOG_LEVEL=INFO
