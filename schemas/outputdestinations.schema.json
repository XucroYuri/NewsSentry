{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://news-sentry.local/schemas/outputdestinations.schema.json",
  "title": "OutputDestinations",
  "description": "Implements: docs/contracts-canonical.md §8; output destination configuration for the output stage",
  "type": "object",
  "required": ["destinations"],
  "additionalProperties": false,
  "properties": {
    "destinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/DestinationConfig"
      }
    }
  },
  "$defs": {
    "DestinationConfig": {
      "type": "object",
      "required": ["destination_id", "type", "enabled"],
      "additionalProperties": false,
      "properties": {
        "destination_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "type": {
          "type": "string",
          "enum": ["obsidian_markdown", "feishu_webhook", "email_smtp", "telegram_bot", "file"],
          "description": "Output destination type; alerts (feishu/email/telegram) never publish content, only notifications"
        },
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "type": "string",
          "description": "Filesystem path for obsidian_markdown/file types"
        },
        "url": {
          "type": "string",
          "description": "Webhook URL for feishu_webhook type; supports ${ENV_VAR} substitution"
        },
        "filename_template": {
          "type": "string",
          "description": "Filename template with {placeholder} variables"
        },
        "frontmatter": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "YAML frontmatter field mappings using Jinja2-style {{ }} templates"
        },
        "filter": {
          "type": "object",
          "additionalProperties": true,
          "description": "Output filter: only write events matching these criteria",
          "properties": {
            "min_news_value_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Minimum news_value_score to trigger"
            },
            "min_china_relevance": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Minimum china_relevance to trigger"
            },
            "recommendation": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed recommendation values"
            }
          }
        },
        "smtp_host": { "type": "string", "description": "SMTP server host (email_smtp type)" },
        "smtp_port": { "type": "integer", "description": "SMTP server port (email_smtp type, default 587)" },
        "smtp_user": { "type": "string", "description": "SMTP username; supports ${ENV_VAR} (email_smtp type)" },
        "smtp_password": { "type": "string", "description": "SMTP password; supports ${ENV_VAR} (email_smtp type)" },
        "from": { "type": "string", "description": "Sender email address (email_smtp type)" },
        "to": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recipient email addresses (email_smtp type)"
        },
        "use_tls": { "type": "boolean", "description": "Use TLS for SMTP (default true)" },
        "bot_token": { "type": "string", "description": "Telegram bot token; supports ${ENV_VAR} (telegram_bot type)" },
        "chat_id": { "type": "string", "description": "Telegram chat ID; supports ${ENV_VAR} (telegram_bot type)" },
        "notes": {
          "type": "string",
          "description": "Human-readable notes about this destination"
        }
      }
    }
  }
}
