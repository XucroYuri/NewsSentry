{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://news-sentry.local/schemas/toolmanifest.schema.json",
  "title": "ToolManifest",
  "description": "Implements: docs/contracts-canonical.md §8; docs/brainstorming/ToolManifest与工具适配层规格.md; ADR-0008; external tool registration",
  "$defs": {
    "ToolManifest": {
      "type": "object",
      "required": [
        "tool_id",
        "display_name",
        "version",
        "execution_type",
        "permissions"
      ],
      "additionalProperties": false,
      "properties": {
        "tool_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"
        },
        "display_name": { "type": "string" },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
        },
        "execution_type": {
          "type": "string",
          "enum": ["subprocess", "http", "python"]
        },
        "command_template": {
          "type": ["string", "null"],
          "description": "Shell command template; null for python/http types. Must not include arbitrary shell commands per ADR-0008."
        },
        "argv_template": {
          "type": ["array", "string", "null"],
          "description": "Argument vector template for subprocess invocation; alternative to command_template for safer argv splitting.",
          "items": { "type": "string" }
        },
        "executable": {
          "type": ["string", "null"],
          "description": "Executable name for subprocess type; resolved via PATH."
        },
        "parameters_schema": {
          "type": "object",
          "description": "JSON Schema for validated_args; arbitrary shell injection prevented by sandbox",
          "additionalProperties": true
        },
        "output_schema": {
          "type": "object",
          "description": "JSON Schema for tool output",
          "additionalProperties": true
        },
        "exit_codes": {
          "type": "object",
          "description": "Map of exit code string to description, e.g. {'0': 'success', '1': 'error'}",
          "additionalProperties": { "type": "string" }
        },
        "exit_code_mapping": {
          "type": "object",
          "description": "Alternative exit code mapping with structured error info.",
          "additionalProperties": { "type": "string" }
        },
        "permissions": { "$ref": "#/$defs/PermissionsBlock" },
        "notes": {
          "type": "string",
          "description": "Optional usage notes or caveats for this tool."
        },
        "phase": {
          "type": "string",
          "description": "Development phase this tool was introduced (e.g. 'Phase 4')."
        },
        "rate_limit": {
          "type": ["object", "string", "null"],
          "description": "Rate limit configuration. Object form: {max_calls_per_hour: N}. String form: '1/s' or '10/min'.",
          "properties": {
            "max_calls_per_hour": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      }
    },
    "PermissionsBlock": {
      "type": "object",
      "title": "PermissionsBlock",
      "required": ["risk_level"],
      "additionalProperties": false,
      "properties": {
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed_hosts": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read_roots": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            },
            "write_roots": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        },
        "browser": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "session_profile_required": { "type": "boolean", "default": false }
          }
        },
        "credentials": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/ToolManifest" },
    {
      "type": "object",
      "required": ["tools"],
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ToolManifest" }
        }
      }
    }
  ]
}
