{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://news-sentry.local/schemas/classification.schema.json",
  "title": "ClassificationRules",
  "description": "Implements: docs/contracts-canonical.md §9; docs/news-classification-framework.md; ADR-0009",
  "type": "object",
  "$defs": {
    "L0Domain": {
      "type": "object",
      "title": "L0Domain",
      "required": ["code", "label_zh"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
          "description": "Code identifier, e.g. 'politics', 'POLITICS'"
        },
        "label_zh": { "type": "string" },
        "label_it": { "type": ["string", "null"] },
        "label_ja": { "type": ["string", "null"] },
        "keywords_it": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "keywords_en": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "keywords_zh": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "keywords_ja": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "L1Topic": {
      "type": "object",
      "title": "L1Topic",
      "required": ["code", "l0_domain", "label_zh"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "l0_domain": { "type": "string" },
        "label_zh": { "type": "string" },
        "label_it": { "type": ["string", "null"] },
        "label_ja": { "type": ["string", "null"] },
        "keywords_it": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "keywords_en": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "keywords_ja": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    }
  },
  "required": ["rules_version"],
  "additionalProperties": false,
  "properties": {
    "extends": {
      "type": "string",
      "description": "Base rules file to inherit from (e.g. 'rules-v1.yaml'). When set, l0_domains can be omitted."
    },
    "rules_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "l0_domains": {
      "type": "array",
      "items": { "$ref": "#/$defs/L0Domain" },
      "default": []
    },
    "l1_topics": {
      "type": "array",
      "items": { "$ref": "#/$defs/L1Topic" },
      "default": []
    },
    "country_axes": {
      "type": "object",
      "description": "Target-specific sub-axes with enable flags: politics, economics, crime, sports, culture",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
