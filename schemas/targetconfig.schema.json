{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://news-sentry.local/schemas/targetconfig.schema.json",
  "title": "TargetConfig",
  "description": "Implements: docs/contracts-canonical.md §11; per-target monitoring configuration; ADR-0015",
  "type": "object",
  "required": [
    "target_id",
    "display_name",
    "language_scope",
    "timezone",
    "source_channel_refs",
    "filter_rules_ref",
    "classification_rules_ref",
    "sandbox_profile_ref",
    "provider_routes_ref",
    "output_destinations_ref"
  ],
  "additionalProperties": false,
  "properties": {
    "target_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Lowercase slug, e.g. 'italy'"
    },
    "display_name": { "type": "string" },
    "monitoring_type": {
      "type": "string",
      "enum": ["country", "topic"],
      "default": "country",
      "description": "Public/admin grouping type. country=国别监控目标, topic=专题监控目标."
    },
    "topic_label": {
      "type": "string",
      "description": "Human topic label for topic targets, e.g. 涉中舆情."
    },
    "language_scope": {
      "type": "object",
      "required": ["primary", "output"],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "string",
          "description": "BCP-47 language code, e.g. 'it'"
        },
        "secondary": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "output": {
          "type": "string",
          "description": "Output language code, e.g. 'zh'"
        }
      }
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone identifier, e.g. 'Europe/Rome'"
    },
    "source_channel_refs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "File refs under config/sources/{target_id}/"
    },
    "filter_rules_ref": { "type": "string" },
    "classification_rules_ref": { "type": "string" },
    "sandbox_profile_ref": { "type": "string" },
    "provider_routes_ref": { "type": "string" },
    "output_destinations_ref": { "type": "string" },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "country_axes": {
          "type": "object",
          "description": "Enable flags for country-specific sub-axes (politics, economics, crime, sports, culture)",
          "additionalProperties": { "type": "boolean" }
        },
        "home_relevance_keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords for computing home_relevance score (0-100). Each hit adds 10, capped at 100.",
          "default": []
        }
      }
    },
    "focus_areas": {
      "type": "array",
      "description": "Priority focus areas for the monitoring target, used to boost relevance scoring",
      "items": {
        "type": "object",
        "required": ["id", "weight", "keywords"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique focus area identifier"
          },
          "weight": {
            "type": "number",
            "minimum": 0.1,
            "maximum": 5.0,
            "description": "Relevance weight multiplier (1.0 = default)"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Keywords that identify this focus area"
          }
        }
      },
      "default": []
    },
    "lifecycle": {
      "type": "object",
      "description": "Target lifecycle state. Missing lifecycle means active for backwards compatibility.",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "archived"],
          "default": "active"
        },
        "archived_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "archive_reason": {
          "type": ["string", "null"]
        }
      },
      "default": { "status": "active" }
    }
  }
}
