# Dockerfile.core — News Sentry 核心镜像（无浏览器）
#
# 仅包含 RSS/API 采集 + 过滤 + AI 研判 + 输出 + API Server
# 适用于: Fly.io / Railway / Render / Cloudflare Containers
#
# 构建命令:
#   docker build -f Dockerfile.core -t news-sentry:core .
#
# 运行:
#   docker run -d --name news-sentry \
#     -e ANTHROPIC_API_KEY=xxx \
#     -v /app/data:/app/data \
#     news-sentry:core
#
# 镜像大小: ~300-400MB | 内存需求: ~1GB

# ── Builder: 仅安装运行时依赖 ──
FROM python:3.12-slim AS builder
WORKDIR /app
COPY pyproject.toml ./
COPY src/ src/
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e ".[api]"

# ── Runtime: 精简运行环境 ──
FROM python:3.12-slim AS runtime
WORKDIR /app

# 最小系统依赖（curl 用于健康检查）
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Python 包（从 builder 复制，不含 dev 依赖）
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# 项目文件
COPY src/ src/
COPY pyproject.toml ./
COPY config/ config/
COPY schemas/ schemas/
RUN pip install --no-cache-dir -e . --no-deps && \
    useradd --create-home appuser && \
    mkdir -p /app/data && chown -R appuser:appuser /app/data

USER appuser
ENV PYTHONUNBUFFERED=1
ENV NEWSSENTRY_IMAGE_TYPE=core

CMD ["python", "-m", "news_sentry.cli", "run", "--target", "italy", "--stage", "all"]
